# ─────────────────────────────────────────────
#  NutriScan AI — Environment Variables
#  Copy this file to .env and fill in your key
#  $ cp .env.example .env
# ─────────────────────────────────────────────

# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: set to "true" for hot-reload during development
FLASK_DEBUG=false

# Optional: change the port (default 5000)
PORT=5000
